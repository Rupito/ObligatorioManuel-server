@{
    ViewData["Title"] = "Seleccionar Socio";
}

<h2>Seleccione el socio</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="ListaPrestamosActivos" method="get">
            <div class="form-group mb-4">
                <label class="control-label font-weight-bold">Socios:</label>
                <select name="idSocio" class="form-control" asp-items="@(new SelectList(ViewBag.Socios, "IdSocio", "NombreCompleto"))" required>
                    <option value="">Seleccione un socio</option>
                </select>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Ver Prestamos Activos</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>