@model StellarMinds.Models.PrestamoModel

@{
    ViewData["Title"] = "Crear Préstamo";
}

<h1>Crear Préstamo</h1>

<h4>Prestamo</h4>
<hr />
<div class="row">
    <div class="col-md-4">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-2">
                <label asp-for="FechaInicio" class="control-label">Fecha Inicio</label>
                <input asp-for="FechaInicio" class="form-control" />
                <span asp-validation-for="FechaInicio" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="FechaFin" class="control-label">Fecha Fin</label>
                <input asp-for="FechaFin" class="form-control" />
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdSocio" class="control-label">Socio</label>
                <select asp-for="IdSocio" class="form-control" asp-items="@(new SelectList(ViewBag.Socios, "IdSocio", "NombreCompleto"))">
                    <option value="">-- Seleccione un Socio --</option>
                </select>
                <span asp-validation-for="IdSocio" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdTelescopio" class="control-label">Telescopio</label>
                <select asp-for="IdTelescopio" class="form-control" asp-items="@(new SelectList(ViewBag.Telescopios, "IdEquipo", "Modelo"))">
                    <option value="">-- Seleccione un Telescopio --</option>
                </select>
                <span asp-validation-for="IdTelescopio" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdMontura" class="control-label">Montura</label>
                <select asp-for="IdMontura" class="form-control" asp-items="@(new SelectList(ViewBag.Monturas, "IdEquipo", "Modelo"))">
                    <option value="">-- Seleccione una Montura --</option>
                </select>
                <span asp-validation-for="IdMontura" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="IdEquipoVisual" class="control-label">(Cámara / Ocular)</label>
                <select asp-for="IdEquipoVisual" class="form-control" asp-items="@(new SelectList(ViewBag.EquiposVisuales, "IdEquipo", "Modelo"))">
                    <option value="">-- Seleccione Cámara u Ocular --</option>
                </select>
                <span asp-validation-for="IdEquipoVisual" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<p class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
</p>