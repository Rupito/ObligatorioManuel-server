@model IEnumerable<StellarMinds.Models.PrestamoModel>

@{
    ViewData["Title"] = "Auditoría de Préstamos";
}

<h2>Información Auditoría de Préstamos</h2>
<hr />

<form asp-action="InformacionAuditoriaPrestamo" method="get" class="row g-3 align-items-end mb-4">
    <div class="col-md-8">
        <label class="form-label fw-bold">Seleccione un Coordinador</label>
        <select name="idCoordinador" class="form-control" required>
            <option value="">-- Seleccione --</option>
            @foreach (SocioModel c in ViewBag.Coordinadores)
            {
                <option value="@c.IdSocio">@c.NombreUsuario</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-dark w-100">Filtrar Auditoría</button>
    </div>
</form>

@if (ViewBag.CoordinadorSeleccionado == null)
{
    <div class="alert alert-secondary text-center">Seleccione un coordinador.</div>
}
else if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center">El coordinador no tiene acciones de alta o devolución.</div>
}
else
{
    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID Préstamo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td><strong>#@p.IdPrestamo</strong></td>
                    <td>
                        <a asp-action="VerAuditoria" asp-route-id="@p.IdPrestamo" class="btn btn-sm btn-info text-white me-2">Ver Auditoría</a>
                        <a asp-action="Details" asp-route-id="@p.IdPrestamo" class="btn btn-sm btn-outline-primary">Detalles</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}