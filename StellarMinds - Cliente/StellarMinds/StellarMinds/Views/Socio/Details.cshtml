@model StellarMinds.Models.SocioModel

@{
    ViewData["Title"] = "Detalle Socio";
}

<h1>Detalle Socio</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.IdSocio</dd>

        <dt class="col-sm-2">Nombre usuario</dt>
        <dd class="col-sm-10">@Model.NombreUsuario</dd>

        <dt class="col-sm-2">Contraseña</dt>
        <dd class="col-sm-10">@Model.Contrasenia</dd>

        <dt class="col-sm-2">Nombre Completo</dt>
        <dd class="col-sm-10">@Model.NombreCompleto</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Telefono</dt>
        <dd class="col-sm-10">@Model.Telefono</dd>

        <dt class="col-sm-2">Direccion</dt>
        <dd class="col-sm-10">@Model.Direccion</dd>

        <dt class="col-sm-2">Rol</dt>
        <dd class="col-sm-10">@Model.Rol</dd>
    </dl>
</div>
